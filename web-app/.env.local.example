# Supabase — get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (use http://localhost:3000 for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Polar — get these from https://polar.sh/dashboard
# Use sandbox for development: https://sandbox.polar.sh/dashboard
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_PRODUCT_PRICE_ID=your-product-price-id
# Set to "sandbox" for dev, "production" for live
POLAR_SERVER=sandbox
